---
// SAFE MODE: I removed the image imports so the build won't crash.
// You can add images back later when you have your screenshots ready.

interface Project {
  title: string;
  link: string;
  preview: string;
  status: string;
}

const projects: Project[] = [
  {
    title: "My First Project",
    link: "https://github.com/AnshSaraswat",
    preview: "https://github.com/AnshSaraswat",
    status: "In Development",
  },
  {
    title: "Cybersecurity Research",
    link: "https://github.com/AnshSaraswat",
    preview: "https://github.com/AnshSaraswat",
    status: "Research",
  },
];
---

<section id="projects" class="py-12 border-t border-[#ffffff10] text-[var(--white)]">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">My work</h2>
    <h3 class="text-4xl md:text-5xl font-medium mb-8">Projects</h3>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {
        projects.map((project) => (
          <div class="group">
            <a href={project.preview} target="_blank" rel="noopener noreferrer" class="block">
              {/* Image section removed for now to fix build */}
              <div class="flex items-center px-3 py-6 border border-[#ffffff10] rounded-2xl bg-[#1414149c]">
                <div class="flex-grow">
                  <h4 class="text-2xl font-semibold">{project.title}</h4>
                  <span class="py-1 text-sm text-[var(--white-icon)]">
                    {project.status}
                  </span>
                </div>
                <div class="flex gap-2 ml-auto">
                    {/* Icons kept simple */}
                     <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-7 text-[var(--white-icon)]">
                       <path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z" />
                     </svg>
                </div>
              </div>
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>